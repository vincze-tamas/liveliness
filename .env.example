# ── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:////data/liveliness.db

# Required: get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Garmin Connect credentials for automatic activity sync
GARMIN_USERNAME=
GARMIN_PASSWORD=

# Directory where uploaded .fit files are stored on disk (inside the container)
FIT_UPLOAD_DIR=/data/fit_files

# Required: random secret for signing tokens — generate with: openssl rand -hex 32
SECRET_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL of the FastAPI backend, as seen from the browser
# Dev: http://localhost:8000  |  Prod: set via docker-compose.prod.yml build arg
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Production / VPS ──────────────────────────────────────────────────────────
# Your domain pointing to the VPS IP (DNS A record must exist for Let's Encrypt)
DOMAIN=liveliness.yourdomain.com

# HTTP Basic Auth — protects the app since it has no built-in user authentication
BASIC_AUTH_USER=admin
# Generate hash: docker run --rm caddy:2-alpine caddy hash-password --plaintext yourpassword
BASIC_AUTH_HASH=

# CORS origins for the backend — must match your domain (JSON array)
CORS_ORIGINS=["https://liveliness.yourdomain.com"]
